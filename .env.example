# ugwtf environment variables
# Copy to .env and fill in your values.
# Existing env vars always take precedence over this file.

# GitHub Personal Access Token (required when `gh` CLI is not installed)
# Scopes needed: repo, workflow, read:org
# GITHUB_TOKEN=ghp_your_token_here

# Alternative token var (GH_TOKEN also accepted)
# GH_TOKEN=ghp_your_token_here
